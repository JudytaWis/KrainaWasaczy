# EmailJS — wysyłka formularzy (kontakt + rezerwacja)
# Skopiuj ten plik do .env.local i uzupełnij wartościami z panelu https://dashboard.emailjs.com
# Wszystkie są publiczne (działają w przeglądarce) — ochrona to "Allowed origins" w panelu EmailJS.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_CONTACT=
NEXT_PUBLIC_EMAILJS_TEMPLATE_RESERVATION=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
